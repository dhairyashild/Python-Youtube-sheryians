# Definition for singly-linked list.
class ListNode:
    def __init__(self, val=0, next=None):
        self.val = val
        self.next = next

"""
-------------------------------------------------------------------------------
PROBLEM 22: Reverse Linked List (LeetCode 206) - FREQUENCY: 10/10
-------------------------------------------------------------------------------
Given head of singly linked list, reverse the list and return its head.

Example: 1->2->3->4->5 -> 5->4->3->2->1
"""
def reverse_list(head):
    prev = None
    curr = head
    
    while curr:
        next_temp = curr.next
        curr.next = prev
        prev = curr
        curr = next_temp
    
    return prev

# Recursive solution
def reverse_list_recursive(head):
    if not head or not head.next:
        return head
    
    new_head = reverse_list_recursive(head.next)
    head.next.next = head
    head.next = None
    
    return new_head

"""
-------------------------------------------------------------------------------
PROBLEM 23: Merge Two Sorted Lists (LeetCode 21) - FREQUENCY: 10/10
-------------------------------------------------------------------------------
Merge two sorted linked lists and return it as sorted new list.

Example: 1->2->4, 1->3->4 -> 1->1->2->3->4->4
"""
def merge_two_lists(list1, list2):
    dummy = ListNode(0)
    curr = dummy
    
    while list1 and list2:
        if list1.val <= list2.val:
            curr.next = list1
            list1 = list1.next
        else:
            curr.next = list2
            list2 = list2.next
        curr = curr.next
    
    curr.next = list1 if list1 else list2
    
    return dummy.next

"""
-------------------------------------------------------------------------------
PROBLEM 24: Linked List Cycle (LeetCode 141) - FREQUENCY: 9/10
-------------------------------------------------------------------------------
Given head of linked list, determine if it has a cycle (pos represents index 
where tail connects to -1 if no cycle).

Example: 3->2->0->-4 (pos=1 connects back to 2) -> true
"""
def has_cycle(head):
    if not head or not head.next:
        return False
    
    slow = head
    fast = head.next
    
    while slow != fast:
        if not fast or not fast.next:
            return False
        slow = slow.next
        fast = fast.next.next
    
    return True

# Alternative (set approach)
def has_cycle_set(head):
    seen = set()
    curr = head
    
    while curr:
        if curr in seen:
            return True
        seen.add(curr)
        curr = curr.next
    
    return False

"""
-------------------------------------------------------------------------------
PROBLEM 25: Reorder List (LeetCode 143) - FREQUENCY: 7/10
-------------------------------------------------------------------------------
Reorder list to L0 → Ln → L1 → Ln-1 → L2 → Ln-2 → ... in-place.

Example: 1->2->3->4 -> 1->4->2->3
"""
def reorder_list(head):
    if not head or not head.next:
        return
    
    # Find middle
    slow, fast = head, head
    while fast and fast.next:
        slow = slow.next
        fast = fast.next.next
    
    # Reverse second half
    prev = None
    curr = slow.next
    slow.next = None  # Split into two lists
    
    while curr:
        next_temp = curr.next
        curr.next = prev
        prev = curr
        curr = next_temp
    
    # Merge two lists
    first, second = head, prev
    while second:
        temp1 = first.next
        temp2 = second.next
        
        first.next = second
        second.next = temp1
        
        first = temp1
        second = temp2

"""
-------------------------------------------------------------------------------
PROBLEM 26: Remove Nth Node From End of List (LeetCode 19) - FREQUENCY: 9/10
-------------------------------------------------------------------------------
Given head of linked list, remove nth node from end and return head.

Example: 1->2->3->4->5, n=2 -> 1->2->3->5
"""
def remove_nth_from_end(head, n):
    dummy = ListNode(0)
    dummy.next = head
    first = second = dummy
    
    # Advance first by n+1 steps
    for _ in range(n + 1):
        first = first.next
    
    # Move first to end, second stays behind
    while first:
        first = first.next
        second = second.next
    
    # Remove nth node
    second.next = second.next.next
    
    return dummy.next

"""
-------------------------------------------------------------------------------
PROBLEM 27: Add Two Numbers (LeetCode 2) - FREQUENCY: 9/10
-------------------------------------------------------------------------------
You are given two non-empty linked lists representing two non-negative integers.
The digits are stored in reverse order, and each node contains a single digit.
Add the two numbers and return the sum as a linked list.

Example: (2 -> 4 -> 3) + (5 -> 6 -> 4) = 7 -> 0 -> 8 (342 + 465 = 807)
"""
def add_two_numbers(l1, l2):
    dummy = ListNode(0)
    curr = dummy
    carry = 0
    
    while l1 or l2 or carry:
        val1 = l1.val if l1 else 0
        val2 = l2.val if l2 else 0
        
        total = val1 + val2 + carry
        carry = total // 10
        curr.next = ListNode(total % 10)
        curr = curr.next
        
        if l1: l1 = l1.next
        if l2: l2 = l2.next
    
    return dummy.next

"""
-------------------------------------------------------------------------------
PROBLEM 28: Find the Duplicate Number (LeetCode 287) - FREQUENCY: 7/10
-------------------------------------------------------------------------------
Given array containing n+1 integers where each integer is between 1 and n,
find the duplicate one. Cannot modify array, constant space.

Example: nums = [1,3,4,2,2] -> 2
"""
def find_duplicate(nums):
    # Floyd's Tortoise and Hare (cycle detection)
    slow = fast = nums[0]
    
    # Find meeting point
    while True:
        slow = nums[slow]
        fast = nums[nums[fast]]
        if slow == fast:
            break
    
    # Find entrance to cycle (duplicate)
    slow = nums[0]
    while slow != fast:
        slow = nums[slow]
        fast = nums[fast]
    
    return slow


