"""
-------------------------------------------------------------------------------
PROBLEM 10: Valid Palindrome (LeetCode 125) - FREQUENCY: 9/10
-------------------------------------------------------------------------------
A phrase is a palindrome if it reads the same forward and backward after 
converting to lowercase and removing non-alphanumeric characters.

Example: "A man, a plan, a canal: Panama" -> true | "race a car" -> false
"""
def is_palindrome(s):
    left, right = 0, len(s) - 1
    
    while left < right:
        while left < right and not s[left].isalnum():
            left += 1
        while left < right and not s[right].isalnum():
            right -= 1
        
        if s[left].lower() != s[right].lower():
            return False
        
        left += 1
        right -= 1
    
    return True

"""
-------------------------------------------------------------------------------
PROBLEM 11: Two Sum II - Input Array Sorted (LeetCode 167) - FREQUENCY: 8/10
-------------------------------------------------------------------------------
Given a 1-indexed sorted array and target, return indices of two numbers that 
add to target. Use constant extra space.

Example: numbers = [2,7,11,15], target = 9 -> [1,2]
"""
def two_sum_sorted(numbers, target):
    left, right = 0, len(numbers) - 1
    
    while left < right:
        curr_sum = numbers[left] + numbers[right]
        if curr_sum == target:
            return [left + 1, right + 1]
        elif curr_sum < target:
            left += 1
        else:
            right -= 1
    
    return []

"""
-------------------------------------------------------------------------------
PROBLEM 12: 3Sum (LeetCode 15) - FREQUENCY: 10/10 (CRITICAL)
-------------------------------------------------------------------------------
Given an integer array nums, return all triplets [nums[i], nums[j], nums[k]] 
such that i != j, i != k, j != k, and nums[i] + nums[j] + nums[k] = 0.
No duplicate triplets allowed.

Example: nums = [-1,0,1,2,-1,-4] -> [[-1,-1,2],[-1,0,1]]
"""
def three_sum(nums):
    nums.sort()
    result = []
    n = len(nums)
    
    for i in range(n - 2):
        # Skip duplicates
        if i > 0 and nums[i] == nums[i - 1]:
            continue
        
        left, right = i + 1, n - 1
        
        while left < right:
            total = nums[i] + nums[left] + nums[right]
            
            if total == 0:
                result.append([nums[i], nums[left], nums[right]])
                
                # Skip duplicates
                while left < right and nums[left] == nums[left + 1]:
                    left += 1
                while left < right and nums[right] == nums[right - 1]:
                    right -= 1
                
                left += 1
                right -= 1
            elif total < 0:
                left += 1
            else:
                right -= 1
    
    return result

"""
-------------------------------------------------------------------------------
PROBLEM 13: Container With Most Water (LeetCode 11) - FREQUENCY: 9/10
-------------------------------------------------------------------------------
Given n non-negative integers representing height of vertical lines, find two 
lines that together with x-axis form container holding the most water.

Example: height = [1,8,6,2,5,4,8,3,7] -> 49
"""
def max_area(height):
    left, right = 0, len(height) - 1
    max_water = 0
    
    while left < right:
        width = right - left
        h = min(height[left], height[right])
        max_water = max(max_water, width * h)
        
        if height[left] < height[right]:
            left += 1
        else:
            right -= 1
    
    return max_water


