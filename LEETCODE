PROBLEM 36: Construct Binary Tree from Preorder and Inorder (LC 105) - FREQ: 7/10
-------------------------------------------------------------------------------
Given preorder and inorder traversal arrays, construct binary tree.

Example: preorder = [3,9,20,15,7], inorder = [9,3,15,20,7] -> tree [3,9,20,null,null,15,7]
"""
def build_tree(preorder, inorder):
    if not preorder or not inorder:
        return None
    
    # First element in preorder is root
    root_val = preorder[0]
    root = TreeNode(root_val)
    
    # Find root in inorder
    mid = inorder.index(root_val)
    
    # Build left and right subtrees
    root.left = build_tree(preorder[1:mid+1], inorder[:mid])
    root.right = build_tree(preorder[mid+1:], inorder[mid+1:])
    
    return root

