-------------------------------------------------------------------------------
Determine if a 9 x 9 Sudoku board is valid. Only the filled cells need to be 
validated according to rules: each row, column, and 3x3 sub-box contains 
digits 1-9 without repetition.

Example: board = 
[["5","3",".",".","7",".",".",".","."]
,["6",".",".","1","9","5",".",".","."]
,[".","9","8",".",".",".",".","6","."]
,["8",".",".",".","6",".",".",".","3"]
,["4",".",".","8",".","3",".",".","1"]
,["7",".",".",".","2",".",".",".","6"]
,[".","6",".",".",".",".","2","8","."]
,[".",".",".","4","1","9",".",".","5"]
,[".",".",".",".","8",".",".","7","9"]] -> true
"""
def is_valid_sudoku(board):
    rows = [set() for _ in range(9)]
    cols = [set() for _ in range(9)]
    boxes = [set() for _ in range(9)]
    
    for i in range(9):
        for j in range(9):
            num = board[i][j]
            if num == '.':
                continue
            
            box_idx = (i // 3) * 3 + (j // 3)
            
            if (num in rows[i] or num in cols[j] or num in boxes[box_idx]):
                return False
            
            rows[i].add(num)
            cols[j].add(num)
            boxes[box_idx].add(num)
    
    return True

"""
-------------------------------------------------------------------------------
PROBLEM 8: Encode and Decode Strings (LeetCode 271) - FREQUENCY: 6/10
-------------------------------------------------------------------------------
Design an algorithm to encode a list of strings to a single string and decode 
it back to the original list. The encoded string should be sent over network.

Example: ["hello","world"] -> encode -> decode -> ["hello","world"]
"""
def encode(strs):
    """Encodes a list of strings to a single string."""
    return ''.join(f"{len(s)}#{s}" for s in strs)

def decode(s):
    """Decodes a single string to a list of strings."""
    result = []
    i = 0
    while i < len(s):
        j = i
        while s[j] != '#':
            j += 1
        length = int(s[i:j])
        result.append(s[j+1:j+1+length])
        i = j + 1 + length
    return result

"""
-------------------------------------------------------------------------------
PROBLEM 9: Longest Consecutive Sequence (LeetCode 128) - FREQUENCY: 8/10
-------------------------------------------------------------------------------
Given an unsorted array of integers nums, return the length of the longest 
consecutive elements sequence. Must run in O(n) time.

Example: nums = [100,4,200,1,3,2] -> 4 (sequence [1,2,3,4])
"""
def longest_consecutive(nums):
    num_set = set(nums)
    longest = 0
    
    for num in num_set:
        # Check if it's start of a sequence
        if num - 1 not in num_set:
            curr = num
            length = 1
            
            while curr + 1 in num_set:
                curr += 1
                length += 1
            
            longest = max(longest, length)
    
    return longest


