# Q1: String Character Count
def count_chars(s):
    counts = {}
    for char in s:
        counts[char] = counts.get(char, 0) + 1
    return counts

# Q2: Reverse String
def reverse_string(s):
    return s[::-1]

# Q3: List Numbers Count (Counts frequency of elements)
def count_list_frequencies(lst):
    freq = {}
    for num in lst:
        freq[num] = freq.get(num, 0) + 1
    return freq

# Q4: Decorator Example
def uppercase_decorator(func):
    def wrapper(text):
        result = func(text)
        return result.upper()
    return wrapper

@uppercase_decorator
def greet(name):
    return f"hello {name}"

# Output execution validations
print("Q1 Target:", count_chars("hello"))          # {'h': 1, 'e': 1, 'l': 2, 'o': 1}
print("Q2 Target:", reverse_string("data"))        # 'atad'
print("Q3 Target:", count_list_frequencies([1, 2, 2, 3])) # {1: 1, 2: 2, 3: 1}
print("Q4 Target:", greet("dheeraj"))              # 'HELLO DHEERAJ'
